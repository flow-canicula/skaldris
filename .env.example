# Copy to .env.local for local dev, or set these in the Vercel project dashboard.
# Everything here ships to the browser — no server-side secrets belong here.

# ── Deployment target ────────────────────────────────────────────────────────
# Vercel: set to your real domain (no trailing slash). basePath will be empty.
# GitHub Pages: set to https://<user>.github.io/jesuke — triggers basePath logic.
NEXT_PUBLIC_SITE_URL=https://www.jesuke.ink

# ── Formspree form IDs ───────────────────────────────────────────────────────
# Get these from formspree.io — they are routing IDs, not secrets.
NEXT_PUBLIC_FORMSPREE_COMMISSION_ID=        # 8-char Formspree form ID (e.g. mzdleqzk)
NEXT_PUBLIC_FORMSPREE_TRADE_ID=             # 8-char Formspree form ID (e.g. mykqeazn)

# ── Optional analytics ───────────────────────────────────────────────────────
# Uncomment if Plausible is enabled; also update the CSP in vercel.json.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jesuke.ink
