				<script>
const icons = [
  "bills-payment-icon",
  "e-load-icon",
  "e-pins-icon",
  "mobile-money-icon",
  "microinsurance-icon",
];

const list = [
  "bills-payment-services-list",
  "e-load-services-list",
  "e-pins-services-list",
  "mobile-money-services-list",
  "microinsurance-services-list",
];

icons.map((icon, index) => {
  const iconSelector = document.getElementById(icon);
  const listSelector = document.getElementById(list[index]);
  let selectedList;

  // Check if iconSelector exists
  if (iconSelector) {
    // Hide the list by default
    listSelector.style.display = "none";

    // Add mouseover event listener to iconSelector
    iconSelector.addEventListener("mouseover", function () {
      listSelector.style.display = "block"; // Show the list
      selectedList = list[index]; // Get the selected list

      // Iterate through the list and hide all unselected lists
      list.forEach((listItem, i) => {
        if (listItem !== selectedList) {
          const unselectedList = document.getElementById(listItem);
          if (unselectedList) {
            unselectedList.style.display = "none";
          }
        }
      });
    });
  }
});


var agents = [
  {
    name: "Anna Marie",
    text: "Simula ng ipakilala sa akin ng aking kuya ang Digipay nagkaroon ako ng kita sa bawat transaksyon na nakatutulong sa akin bilang isang mag-aaral.",
    image: "https://digipay.ph/wp-content/uploads/2024/05/Anna-Marie.jpeg",
    details: {
      occupation: "Owner of Arnold Dry Goods Store",
      location: "Quezon Province",
    },
  },

  {
    name: "Arnold Vender",
    text: "Bilang isang authorized Digipay Agent/Distributor, ako po ay lubos nagpapasalamat dahil ang Digipay ay isa sa aking katuwang at kasama sa pagpapalago at pagbibigay ng dekalidad at mapagkakatiwalaang serbisyong pinansyal.",
    image: "https://digipay.ph/wp-content/uploads/2024/05/Arnold.jpeg",
    details: {
      occupation:
        "Owner of Arnold’s Bills Payment, Reloading & Remittance Services",
      location: "Quezon Province",
    },
  },

  {
    name: "Liandro",
    text: "Since nagsimula kami ng maliit na pagkakakitaan, ang DIGIPAY ang una namin naging partner.",
    image: "https://digipay.ph/wp-content/uploads/2024/05/Liandro.jpg",
    details: {
      occupation: "Owner of KKNJZY e-Sari and Payments Online Shop",
      location: "Romblon",
    },
  },

  {
    name: "Rebecca",
    text: "Digipay is the reason I acquired more friends, and it has made my life better.",
    image: "https://digipay.ph/wp-content/uploads/2024/05/Rebecca.jpeg",
    details: {
      occupation: "Owner of Travelmate Bills Payment",
      location: "Taguig",
    },
  },
];

function showTestimonial() {
  const testmonialContent = document.getElementById("testimonials-content");
  const agentQuote = document.getElementById("agent-quote");
  const agentFullName = document.getElementById("agent-full-name");
  const agentImage = document.getElementById("agent-image");
  const agentDescription = document.getElementById("agent-description");
  const agentLocation = document.getElementById("agent-location");
  let index = 0;

  const updateContent = () => {
    agentQuote.innerHTML = agents[index].text;
    agentFullName.innerHTML = agents[index].name;
    agentImage.src = agents[index].image;
    agentDescription.innerHTML = agents[index].details.occupation;
    agentLocation.innerHTML = agents[index].details.location;
    index = (index + 1) % agents.length;
  };

  if(index === 0){
     testmonialContent.classList.add("show");
  }

  const showNextContent = () => {
    testmonialContent.classList.remove("show");
    setTimeout(() => {
      updateContent();
      testmonialContent.classList.add("show");
    }, 1000);
  };

  setInterval(() => {
    showNextContent();
  }, 10000);
}

document.addEventListener('DOMContentLoaded', () => {
  showTestimonial();
});




</script>		</div>

